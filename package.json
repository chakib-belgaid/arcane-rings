    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/bun": "^1.3.4",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/seedrandom": "^3.0.8",
    "@vitejs/plugin-react": "^4.5.0",
    "fast-check": "^3.23.2",
    "jsdom": "^25.0.1",
